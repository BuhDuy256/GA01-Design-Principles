                                <strong>AND:</strong> Results must contain all keywords. 
                                <strong>OR:</strong> Results contain at least one keyword.
                            </small>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2">
                            <button class="btn btn-lg fw-bold flex-fill shadow-sm" type="submit"
                                style="background: linear-gradient(135deg, #72AEC8 0%, #5a9bb8 100%); color: white; border: none;">
                                <i class="bi bi-search me-2"></i>Search
                            </button>
                            <button class="btn btn-lg btn-outline-secondary" type="button" data-bs-dismiss="modal">
