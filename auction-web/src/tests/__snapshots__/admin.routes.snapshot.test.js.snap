                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="logic" id="logicOr" value="or">
                                    <label class="form-check-label" for="logicOr">
                                        <strong>OR</strong>
                                    </label>
                                </div>
                            </div>
                            <small class="text-muted d-block mt-2">
                                <i class="bi bi-info-circle"></i> 
                                <strong>AND:</strong> Results must contain all keywords. 
                                <strong>OR:</strong> Results contain at least one keyword.
                            </small>
                        </div>

