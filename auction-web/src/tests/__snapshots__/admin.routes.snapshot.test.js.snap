    </main>

    <footer id="footer" class="py-5 bg-dark text-white mt-auto">
      <div class="container">
        <div class="row">
          <div class="col-md-4 mb-3">
            <h5 class="text-uppercase mb-3">Online Auction</h5>
            <p class="small text-muted">The best place to find and bid on unique items.</p>
          </div>
          <div class="col-md-4 mb-3">
            <h5 class="text-uppercase mb-3">Quick Links</h5>
            <ul class="list-unstyled small">
              <li><a href="/" class="text-decoration-none text-muted">Home</a></li>
              <li><a href="#" class="text-decoration-none text-muted">About Us</a></li>
              <li><a href="#" class="text-decoration-none text-muted">Terms of Service</a></li>
            </ul>
          </div>
          <div class="col-md-4 mb-3">
            <h5 class="text-uppercase mb-3">Contact</h5>
            <p class="small text-muted">Email: support@auction.com</p>
            <p class="small text-muted">Phone: +84 123 456 789</p>
